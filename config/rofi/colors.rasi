// Set colors and font from enviroment variables, with Nord color fallbacks.
// These environment variables are set when Rofi is invoked through the
// script scripts/rofi-wrapper.sh

configuration {
    font:                   env(ROFI_FONT, "Fira Sans 13");
}

* {
    background-color:       transparent;
    background:             env(ROFI_BACKGROUND_COLOR,          #000000);
    background-transparent: env(ROFI_BACKGROUND_TRANSPARENT,    #000000CF);
    text-color:             env(ROFI_TEXT_COLOR,                #D8DEE9);
    primary:                env(ROFI_ACCENT_COLOR,              #FD5A3A);
    secondary:              env(ROFI_SECONDARY_COLOR,           #EFB86B);
    urgent:                 env(ROFI_URGENT_COLOR,              #ff3c26);
    primary: #a7c8ff;
    primary-fixed: #d5e3ff;
    primary-fixed-dim: #a7c8ff;
    on-primary: #04305f;
    on-primary-fixed: #001b3c;
    on-primary-fixed-variant: #244777;
    primary-container: #244777;
    on-primary-container: #d5e3ff;
    secondary: #bdc7dc;
    secondary-fixed: #d9e3f8;
    secondary-fixed-dim: #bdc7dc;
    on-secondary: #273141;
    on-secondary-fixed: #121c2b;
    on-secondary-fixed-variant: #3d4758;
    secondary-container: #3d4758;
    on-secondary-container: #d9e3f8;
    tertiary: #dbbce1;
    tertiary-fixed: #f8d8fe;
    tertiary-fixed-dim: #dbbce1;
    on-tertiary: #3e2845;
    on-tertiary-fixed: #27132f;
    on-tertiary-fixed-variant: #563e5d;
    tertiary-container: #563e5d;
    on-tertiary-container: #f8d8fe;
    error: #ffb4ab;
    on-error: #690005;
    error-container: #93000a;
    on-error-container: #ffdad6;
    surface: #111318;
    on-surface: #e1e2e9;
    on-surface-variant: #c4c6cf;
    outline: #8e9199;
    outline-variant: #43474e;
    shadow: #000000;
    scrim: #000000;
    inverse-surface: #e1e2e9;
    inverse-on-surface: #2e3035;
    inverse-primary: #3e5f90;
    surface-dim: #111318;
    surface-bright: #37393e;
    surface-container-lowest: #0c0e13;
    surface-container-low: #191c20;
    surface-container: #1d2024;
    surface-container-high: #282a2f;
    surface-container-highest: #33353a;
}

