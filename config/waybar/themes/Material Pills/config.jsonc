{
    "position": "top",
    "margin-top": 4,
    "modules-left": ["custom/apps", "clock", "mpris"],
    "modules-center": [ "hyprland/workspaces", "custom/notification"],
    "modules-right":[
        "tray",
        "pulseaudio",
        "network",
    ],


    //MODULES//

	"custom/apps": { 
	    "format": "Quentin",
		"font-family": "UbuntuMonoNerdFont",
		"font-weight": 400,
		"on-click": "~/.config/rofi/scripts/menu.sh"
        // "on-click": "rofi -show drun"
	}, 

    "clock": {
        "format": "п’«    {:%H:%M}", // AM PM format
        //"format": "пҖ—  {:%H:%M}",// 24H
        "format-alt": "пҒі    {:%a %e %b}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "hyprland/workspaces": {
	    "persistent-workspaces": {"*": [ 1,2,3,4,5 ]},
	    "on-click": "activate",
        "format": "{icon} {windows}",
        "format-icons": {
		    "1": "дёҖ",
		    "2": "дәҢ",
		    "3": "дёү",
		    "4": "еӣӣ",
		    "5": "дә”",
		    "6": "е…ӯ",
		    "7": "дёғ",
		    "8": "е…«",
		    "9": "д№қ",
            "10": "еҚҒ",
            "urgent": "пҒӘ",
            "focused": "пҶ’",
            "default": ""
        },
	    "format-window-separator": " ",
	    "window-rewrite-default": "пҒҷ ",
	    "window-rewrite": {		
            "class<.*imv*.>": "п“Ҙ ",
            "class<.*bambustudio*.>": "у°җ« ",
            "class<.*bitwarden*.>": "оҙҘ ",
            "class<.*handbrake*.>": "у°Ҳ« ",
            "class<.*stremio*.>": "уұ–Ҹ ",
            "title<.*waydroid*.>": "оңҺ ",
            "class<.*grayjay*.>": "уұ—Ҷ ",
	    	"title<.*amazon.*>": "пү° ",
	    	"class<firefox|org.mozilla.firefox|librewolf|floorp|mercury-browser|[Cc]achy-browser>": "оқ… ",
	    	"class<zen>": "у°°· ",
	    	"class<waterfox|waterfox-bin>": "оә“ ",
	    	"class<microsoft-edge>": "пҠӮ ",
	    	"class<Chromium|Thorium|[Cc]hrome>": "пүЁ ",
	    	"class<brave-browser>": "рҹҰҒ ",
	    	"class<tor-browser>": "пҚұ ",
	    	"class<firefox-developer-edition>": "рҹҰҠ ",
	    	"class<kitty|konsole>": "оһ• ",
	    	"class<kitty-dropterm>": "п„  ",
	    	"class<com.mitchellh.ghostty>": "оһ• ",
	    	"class<org.wezfurlong.wezterm>": "оӘ… ",
            "class<org.omarchy.terminal>": "у°Ҹ– ",
	    	"class<[Tt]hunderbird|[Tt]hunderbird-esr>": "пҚ° ",
	    	"class<eu.betterbird.Betterbird>": "пҚ° ",
	    	"title<.*gmail.*>": "у°Ҡ« ",
	    	"class<[Tt]elegram-desktop|org.telegram.desktop|io.github.tdesktop_x64.TDesktop>": "оҲ— ",
	    	"class<discord|[Ww]ebcord|Vesktop>": "пҮҝ ",
	    	"title<.*whatsapp.*>": "пҲІ ",
        "title<.*zapzap.*>": "пҲІ ",
	    	"title<.*messenger.*>": "пүҹ ",
	    	"title<.*facebook.*>": "пӮҡ ",
	    	"title<.*reddit.*>": "пҠҒ ",
	    	"title<.*ChatGPT.*>": "у°ҡ© ",
        "class<.*ChatGPT.*>": "у°ҡ© ",
	    	"title<.*deepseek.*>": "у°ҡ© ",
	    	"title<.*qwen.*>": "у°ҡ© ",
	    	"class<subl>": "у°…і ",
	    	"class<slack>": "пҶҳ ",
	    	"class<mpv>": "пҚ® ",
	    	"class<celluloid|Zoom>": "пҖҪ ",
	    	"class<Cider>": "у°ҺҶ ",
	    	"title<.*Picture-in-Picture.*>": "п”¬ ",
	    	"title<.*youtube.*>": "п…Ә ",
	    	"class<vlc>": "у°•ј ",
	    	"title<.*cmus.*>": "пҖҒ ",
            "title<.*kew.*>": "пҖҒ ",
	    	"class<[Ss]potify>": "пҶј ",
	    	"class<virt-macodeger>": "оӯ» ",
	    	"class<.virt-manager-wrapped>": "оӯ» ",
	    	"class<virtualbox manager>": "рҹ’Ҫ",
	    	"title<virtualbox>": "рҹ’Ҫ",
	    	"class<remmina>": "рҹ–ҘпёҸ",
	    	"class<VSCode|code-url-handler|code-oss|codium|codium-url-handler|VSCodium>": "у°Ёһ ",
        "class<dev.zed.Zed>": "у°өҒ ",
	    	"class<codeblocks>": "у°…© ",
	    	"title<.*github.*>": "п„“ ",
	    	"class<mousepad>": "п…ң ",
	    	"class<libreoffice-writer>": "оҡҘ ",
	    	"class<libreoffice-startcenter>": " у°ҸҶ ",
	    	"class<libreoffice-calc>": "пҚ» ",
	    	"title<.*nvim ~.*>": "пҚҜ ",
        "class<org.gnome.Nautilus>": "у°ЈҶ ",
	    	"title<.*vim.*>": "оҹ… ",
	    	"title<.*figma.*>": "оҪҮ ",
	    	"title<.*jira.*>": "оқң ",
	    	"class<jetbrains-idea>": "оһө ",
        "title<*.VSCode.*>": "у°Ёһ ",
        "class<.*code.*>": "у°Ёһ ",
	    	"class<obs|com.obsproject.Studio>": "о®§ ",
	    	"class<polkit-gnome-authentication-agent-1>": "у°’ғ ",
	    	"class<nwg-look>": "оӯ’ ",
	    	"class<[Pp]avucontrol|org.pulseaudio.pavucontrol>": "уұЎ«",
	    	"class<steam>": "пҶ¶ ",
	    	"class<thunar|nemo>": "у°қ° ",	
        "class<Gparted>":"пғҮ ",
	    	"class<gimp>": "пҢё ",
	    	"class<emulator>": "рҹ“ұ",
	    	"class<android-studio>": "п…» ",
       	"class<org.pipewire.Helvum>": "у°“ғ",
        "class<localsend>":"пҮ  ",
        "class<PrusaSlicer|UltiMaker-Cura|OrcaSlicer>": "у°№ӣ "
	    	}
	    },

    "tray": {
    "icon-size": 16,
    "spacing": 10,
    },

    "pulseaudio": {
    "format": "{icon} {volume}%",
    "on-click": "pulsemixer",
    "on-click-right": "pulsemixer",
    "tooltip-format": "Playing at {volume}%",
    "scroll-step": 5,
    "format-muted": "о»Ё ",
    "format-icons": {
      "default": [
        "пҖҰ",
        "пҖ§ ",
        "пҖЁ "
       ]
     }
    },

    "network": {
     "format-icons": ["у°ӨҜ ", "у°Өҹ ", "у°Өў ", "у°ӨҘ ", "у°ӨЁ "],
     "format": "{icon}",
     "format-wifi": "{icon}",
     "format-ethernet": "у°Ңҳ   ethernet",
     "format-disconnected": "у°Ө® ",
     "tooltip-format-wifi": "{essid} ({frequency} GHz)\nвҮЈ{bandwidthDownBytes}  вҮЎ{bandwidthUpBytes}",
     "tooltip-format-ethernet": "вҮЈ{bandwidthDownBytes}  вҮЎ{bandwidthUpBytes}",
     "tooltip-format-disconnected": "Disconnected",
     "interval": 3,
     "spacing": 1,
     "on-click": "omarchy-launch-wifi"
    },

   "custom/notification": {
      "tooltip": true,
      "format": "<span size='16pt'>{icon}</span>",
      "format-icons": {
        "notification": "уұ…« ",
        "none": "у°Ӯң ",
        "dnd-notification": "у°Ӯ  ",
        "dnd-none": "у°Ә“ ",
        "inhibited-notification": "у°Ӯӣ ",
        "inhibited-none": "у°Ә‘ ",
        "dnd-inhibited-notification": "у°Ӯӣ ",
        "dnd-inhibited-none": "у°Ә‘ "
      },
      "return-type": "json",
      "exec-if": "which swaync-client",
      "exec": "swaync-client -swb",
      "on-click": "swaync-client -t -sw",
      "on-click-right": "swaync-client -d -sw",
      "escape": true
    },

    "mpris": {
	    "interval": 10,
	    "format": "{player_icon}  {dynamic}",
	    "format-paused": "{status_icon}  {artist}",
	    "on-click-middle": "playerctl play-pause",
	    "on-click": "playerctl previous",
	    "on-click-right": "playerctl next",
	    "scroll-step": 5.0,
	    "on-scroll-up": "$HOME/.config/hypr/scripts/volume.sh --inc",
	    "on-scroll-down": "$HOME/.config/hypr/scripts/volume.sh --dec",
	    "smooth-scrolling-threshold": 1,
	    "tooltip": true,
	    "tooltip-format": "{status_icon} {title}\nLeft Click: previous\nMid Click: Pause\nRight Click: Next",
	    "player-icons": {
	    	"chromium": "пүЁ ",
	    	"default": "пҖқ ",
	    	"firefox": "пү© ",
	    	"kdeconnect": "пҳҹ ",
	    	"mopidy": "пҖҒ ",
	    	"mpv": "у°җ№ ",
	    	"spotify": "у°ҺҶ ",
	    	"vlc": "у°•ј ",
	    },
	    "status-icons": {
	    	"paused": "пҒҢ",
	    	"playing": "пҒӢ",
	    	"stopped": "пҒҚ",
	    },
	    "dynamic-order": ["artist"],
	    "ignored-players": [ "zen"],
	    "max-length": 25,
    },

	"custom/screenrecording-indicator": {
		"format": "пҖҪ ",
        "on-click": "kitty --title=Recorder sh -c '~/.config/hypr/scripts/screenrec.sh'",
        "signal": 8,
		"tooltip": false,
        "return-type": "json"
  },
}
